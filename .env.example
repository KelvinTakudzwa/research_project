# ─── System Identity ─────────────────────────────────────────────────────────
# BATTERY_CHEMISTRY: drives V_min/V_max via cell-level lookup table.
# Valid values: LEAD_ACID | AGM | LITHIUM | LIFEPO4 | LITHIUM_ION | NMC
# Missing or invalid value → process.exit(1) at boot.
BATTERY_CHEMISTRY=LEAD_ACID

# Pack voltage — combined with chemistry to compute cell count and SoC bounds.
# Valid values: 12 | 24 | 48
BATTERY_NOMINAL_VOLTAGE_V=12

# ─── Rated Specs (used for Ohm's Law fallback when MAX_* not set) ─────────────
RATED_PV_WATTAGE_W=200
RATED_INVERTER_WATTAGE_W=300

# ─── Physical Maxima (leave blank to derive via Ohm's Law) ───────────────────
# MAX_PV_VOLTAGE_V: open-circuit voltage from panel datasheet — provide explicitly
MAX_PV_VOLTAGE_V=21.6
# MAX_PV_CURRENT_A:   derived as RATED_PV_WATTAGE_W / BATTERY_NOMINAL_VOLTAGE_V
MAX_PV_CURRENT_A=
# MAX_PV_POWER_W:     derived as RATED_PV_WATTAGE_W
MAX_PV_POWER_W=
# MAX_BATTERY_VOLTAGE_V: derived as BATTERY_NOMINAL_VOLTAGE_V * 1.15 (bulk charge ceiling)
MAX_BATTERY_VOLTAGE_V=
# MAX_BATTERY_CURRENT_A: derived as RATED_PV_WATTAGE_W / BATTERY_NOMINAL_VOLTAGE_V
MAX_BATTERY_CURRENT_A=
# MAX_AC_POWER_W:     derived as RATED_INVERTER_WATTAGE_W
MAX_AC_POWER_W=
MAX_AC_VOLTAGE_V=240
# MAX_AC_CURRENT_A:   derived as MAX_AC_POWER_W / MAX_AC_VOLTAGE_V
MAX_AC_CURRENT_A=
MAX_IRRADIANCE_WM2=1000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT secret for dashboard users (React frontend → Node.js)
JWT_SECRET=change-me-dashboard-secret
# JWT secret for service-to-service auth (Node.js → FastAPI ML engine)
JWT_SERVICE_SECRET=change-me-service-secret
# Single-operator credentials
# DASHBOARD_PASSWORD is plain text — the Node.js backend hashes it in-memory
# at startup using bcrypt. This avoids Docker Compose expanding the $ signs
# that bcrypt hashes contain.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me-password

# ─── Services ─────────────────────────────────────────────────────────────────
ML_API_URL=http://ml-api:8000
DB_HOST=db
DB_USER=root
DB_PASSWORD=0786682192@Tk
DB_NAME=solar_monitoring
MQTT_BROKER=mqtt://broker:1883
